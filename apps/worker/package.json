{
  "name": "@assetx/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --env-file=../../.env --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@assetx/image-processing": "workspace:*",
    "@assetx/publishing": "workspace:*",
    "@assetx/queue": "workspace:*",
    "@assetx/shared-types": "workspace:*",
    "@assetx/storage": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
