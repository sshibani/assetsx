{
  "name": "@assetx/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@assetx/auth": "workspace:*",
    "@assetx/image-processing": "workspace:*",
    "@assetx/publishing": "workspace:*",
    "@assetx/queue": "workspace:*",
    "@assetx/shared-types": "workspace:*",
    "@assetx/storage": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.1.0",
    "file-type": "^19.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
