**/*.sqlite-journal
apps/api/prisma/dev.sqlite

# Env & secrets (provided via env_file)
.env
.env.local
**/.env
**/.env.local

# VCS & misc
.git
.gitignore
*.log
npm-debug.log*
.DS_Store
coverage
