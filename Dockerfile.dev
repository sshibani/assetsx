# Shared development image for all AssetX apps (api, worker, web).
# Source is bind-mounted at runtime (see docker-compose.yml) so this image
# only needs the toolchain + installed node_modules for hot-reload dev.
FROM node:22-bookworm-slim

# Native deps required by sharp / argon2 / prisma at build & runtime.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        openssl \
        ca-certificates \
        python3 \
        make \
        g++ \
    && rm -rf /var/lib/apt/lists/*

# Enable pnpm via corepack, pinned to the repo's packageManager.
RUN corepack enable && corepack prepare pnpm@11.7.0 --activate

WORKDIR /app

# Install dependencies first for better layer caching. Copy only manifests.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc* turbo.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/worker/package.json ./apps/worker/
COPY apps/web/package.json ./apps/web/
COPY packages/auth/package.json ./packages/auth/
COPY packages/image-processing/package.json ./packages/image-processing/
COPY packages/publishing/package.json ./packages/publishing/
COPY packages/queue/package.json ./packages/queue/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/storage/package.json ./packages/storage/

RUN pnpm install --frozen-lockfile

# Copy the rest of the source (overridden by bind mounts in dev compose).
COPY . .

# Build workspace packages so apps resolve to their dist/ output, and
# generate the Prisma client for the container's platform.
RUN pnpm --filter "./packages/*" build \
    && pnpm --filter @assetx/api prisma:generate

# Default command is overridden per-service in docker-compose.yml.
CMD ["pnpm", "--filter", "@assetx/api", "dev"]
