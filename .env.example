# ─────────────────────────────────────────────────────────────────────────────
# AssetX — consolidated environment template.
# Copy to `.env` (git-ignored) before running docker compose:
#   cp .env.example .env
# All services (api, worker, web) read from this single file via compose env_file.
# Paths below are CONTAINER paths (see docker-compose.yml volumes).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database (SQLite on the shared `app-data` volume) ──
DATABASE_URL=file:/data/db/dev.sqlite

# ── API ──
PORT=3001

# ── Auth (JWT) — change the secrets for any non-local use ──
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Storage (files on the shared `app-data` volume) ──
STORAGE_ROOT=/data/storage
PUBLIC_BASE_URL=http://localhost:3001/files

# ── Redis / queue (service name on the compose network) ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Web → API (server-side rewrite target on the compose network) ──
API_URL=http://api:3001

# ── Seed super user ──
ADMIN_EMAIL=admin@assetx.local
ADMIN_PASSWORD=admin12345
